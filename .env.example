# Copy this file to `.env` before running `docker compose up -d`.
# Replace every placeholder with your own production value.

# Docker host port mapping for the new-api container.
# Keep APP_BIND_IP at 127.0.0.1 when using Nginx/Caddy on the same host.
# APP_PORT is used both for the published host port and the container PORT env.
APP_BIND_IP=127.0.0.1
APP_PORT=3000
TZ=Asia/Shanghai
NODE_NAME=new-api-node-1

# Required secrets. Use long random strings.
SESSION_SECRET=replace_with_a_long_random_session_secret
CRYPTO_SECRET=replace_with_a_different_long_random_crypto_secret

# PostgreSQL settings used by docker-compose.yml
POSTGRES_USER=newapi
POSTGRES_PASSWORD=replace_with_a_strong_postgres_password
POSTGRES_DB=new-api

# Redis password used by docker-compose.yml
REDIS_PASSWORD=replace_with_a_strong_redis_password

# Recommended runtime settings
ERROR_LOG_ENABLED=true
BATCH_UPDATE_ENABLED=true
STREAMING_TIMEOUT=300

# Keep disabled in production
TLS_INSECURE_SKIP_VERIFY=false

# Optional examples
# FRONTEND_BASE_URL=https://your-frontend.example.com
# SYNC_FREQUENCY=60
# CHANNEL_UPDATE_FREQUENCY=30
# RELAY_TIMEOUT=0
# TRUSTED_REDIRECT_DOMAINS=example.com,myapp.io

# LinuxDo defaults
LINUX_DO_TOKEN_ENDPOINT=https://connect.linux.do/oauth2/token
LINUX_DO_USER_ENDPOINT=https://connect.linux.do/api/user
