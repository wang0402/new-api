# Copy this file to a safe location such as `.env.next` and fill in the real values.
# Do not overwrite the live `.env` until your maintenance window starts.

APP_BIND_IP=127.0.0.1
APP_PORT=3000
TZ=Asia/Shanghai
NODE_NAME=new-api-node-1

SESSION_SECRET=replace_with_a_long_random_session_secret
CRYPTO_SECRET=replace_with_a_different_long_random_crypto_secret

POSTGRES_USER=newapi
POSTGRES_PASSWORD=replace_with_a_strong_postgres_password
POSTGRES_DB=new-api

REDIS_PASSWORD=replace_with_a_strong_redis_password

ERROR_LOG_ENABLED=true
BATCH_UPDATE_ENABLED=true
STREAMING_TIMEOUT=300
TLS_INSECURE_SKIP_VERIFY=false

# Optional but recommended once the site is exposed publicly.
# FRONTEND_BASE_URL=https://transferapi.space
