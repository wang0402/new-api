NEW_API_VERSION=latest
# Optional: set this when using ./up-image.sh with your own prebuilt image.
# NEW_API_IMAGE=ghcr.io/your-org/new-api:latest
# Optional: used by ./build-push-image.sh
# NEW_API_PLATFORM=linux/amd64
# NEW_API_PUSH_MODE=push
NEW_API_BIND_ADDRESS=127.0.0.1
NEW_API_PORT=3001

POSTGRES_USER=newapi
POSTGRES_PASSWORD=change-me
POSTGRES_DB=new-api

REDIS_PASSWORD=change-me
CRYPTO_SECRET=change-me
SESSION_SECRET=change-me

STREAMING_TIMEOUT=300
ERROR_LOG_ENABLED=true
NODE_NAME=new-api-node-1
TZ=Asia/Shanghai
TLS_INSECURE_SKIP_VERIFY=false
GIN_MODE=release
BATCH_UPDATE_ENABLED=true
